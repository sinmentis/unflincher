# deploy/quadlet/diary.container
[Unit]
Description=diary.yourdomain.com — AI-annotated diary (FastAPI + htmx + SSE, in-process async batch worker)

[Container]
Image=localhost/diary:latest
ContainerName=diary

# Loopback only. cloudflared maps diary.yourdomain.com -> http://localhost:8096 (see
# deploy/cloudflared/diary-ingress.snippet.yml, Task 20). PRIVATE behind Cloudflare Access.
PublishPort=127.0.0.1:8096:8000

Volume=diary-data.volume:/data

# LLM API key — created once via `podman secret create diary-llm-key ...` (Task 21). Never
# in the image or in git.
Secret=diary-llm-key,type=env,target=ANTHROPIC_API_KEY

Environment=DIARY_DB=/data/diary.db
Environment=DIARY_LLM_MODEL=anthropic/claude-sonnet-4-5
Environment=DIARY_BATCH_CONCURRENCY=3
Environment=DIARY_CF_TEAM_DOMAIN=REPLACE_WITH_TEAM_DOMAIN
Environment=DIARY_CF_ACCESS_AUD=REPLACE_WITH_ACCESS_APP_AUD
Environment=DIARY_OPERATOR_EMAIL=REPLACE_WITH_OPERATOR_EMAIL
Environment=DIARY_REQUIRE_ACCESS_AUTH=true

HealthCmd=python -c "import urllib.request,sys; sys.exit(0 if urllib.request.urlopen('http://127.0.0.1:8000/healthz',timeout=5).status==200 else 1)"
HealthInterval=60s
HealthTimeout=10s
HealthRetries=3
HealthStartPeriod=30s
# Deliberately NO HealthOnFailure=kill — a health blip must never interrupt an in-flight
# apply-to-all batch (technical design §7.4/§7.6). Restart=always below covers real crashes.

PodmanArgs=--stop-timeout=30

[Service]
Restart=always
RestartSec=5
TimeoutStartSec=90
TimeoutStopSec=45

[Install]
WantedBy=default.target
